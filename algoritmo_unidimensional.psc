Algoritmo algoritmo_unidimensional
	Definir num, i Como Entero
	Dimension num[5]
	
	
	para i <- 1 hasta 5 con paso 1 Hacer
		Escribir "Escribe numeros de 10 en 10 hasta 50: "
		leer num[i]
	FinPara
	
	para i <- 1 Hasta 5 Con Paso 1 Hacer
		Escribir "La lista, de los numeros es: ", num[i]
	FinPara
FinAlgoritmo
